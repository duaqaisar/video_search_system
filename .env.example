# Copy this file to .env and fill in real values.
# Never commit the actual .env file — it's already excluded in .gitignore.

# Hugging Face token — required for downloading gated/private models
# (e.g. Whisper, diarization, or vision-language models used in the pipeline).
# Get one at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# OpenRouter API key — used for keyframe captioning / summary generation
# (Qwen2.5-VL via OpenRouter, per generate_video_summary.py).
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Secret used to sign/verify JWTs for authenticated API access.
# Generate a strong random value, e.g.: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here
