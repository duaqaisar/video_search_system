# Copy this file to .env and fill in real values.
# Never commit the actual .env file — it's already excluded in .gitignore.

# --- External APIs ---

# Hugging Face token — required for downloading the gated pyannote
# speaker-diarization model (app/core/diarization.py).
# Get one at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# OpenRouter API key — used for summary/chapter generation (summary.py)
# and video Q&A chat (video_chat.py), via free-tier models.
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Auth ---

# Secret used to sign/verify JWTs for authenticated API access.
# Generate a strong random value, e.g.: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# --- Database (PostgreSQL) ---
# Defaults below match docker-compose.yml's postgres service.
DATABASE_URL=postgresql://videoapp:videoapp_dev_password@localhost:5432/video_search

# --- Object storage (S3-compatible; MinIO locally, real S3 in production) ---
# Defaults below match docker-compose.yml's minio service.
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=videoapp
S3_SECRET_KEY=videoapp_dev_password
S3_BUCKET=videos

# --- Celery broker/backend (Redis) ---
REDIS_URL=redis://localhost:6379/0

# --- Vector search (Qdrant) ---
QDRANT_URL=http://localhost:6333
